{
  "expo": {
    "name": "Hygiena+",
    "slug": "hygiena-plus",
    "scheme": "hygienaplus",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/logo/hygiena-icon-1024-full.png",
    "splash": {
      "image": "./assets/logo/hygiena-icon-1024.png",
      "resizeMode": "contain",
      "backgroundColor": "#D1FAE5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hygiena.plus"
    },
    "android": {
      "package": "com.hygiena.plus",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo/hygiena-icon-1024.png",
        "backgroundColor": "#D1FAE5"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Hygiena+ a besoin d'accéder à vos photos pour ajouter une image de produit."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Hygiena+ utilise Face ID pour protéger l'accès à vos données."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
